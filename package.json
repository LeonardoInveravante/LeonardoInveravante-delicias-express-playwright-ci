{
  "name": "delicias-express-web",
  "version": "1.0.0",
  "description": "Web local-first para laboratorio de Playwright, organización de tests, Page Objects, Component Objects, fixtures y patrones.",
  "main": "index.js",
  "scripts": {
    "start": "vite ./web --host 127.0.0.1 --port 4173",
    "test": "playwright test",
    "test:ci": "playwright test --project=chromium",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint \"**/*.{js,mjs,cjs,ts}\"",
    "lint:fix": "eslint \"**/*.{js,mjs,cjs,ts}\" --fix",
    "lint:strict": "eslint \"**/*.{js,mjs,cjs,ts}\" --max-warnings=0",
    "lint:playwright": "eslint \"tests/**/*.ts\"",
    "validate:html": "html-validate \"web/**/*.html\"",
    "lint:css": "stylelint \"web/**/*.css\"",
    "quality": "npm run lint && npm run validate:html && npm run lint:css",
    "ci": "npm run quality && npm run test:ci"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.5.0",
    "eslint-plugin-playwright": "^2.10.4",
    "globals": "^17.6.0",
    "html-validate": "^11.5.3",
    "http-server": "^14.1.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript-eslint": "^8.61.0"
  }
}
